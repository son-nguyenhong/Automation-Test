{
  "id": "tc_example_001",
  "name": "Account Management - Toggle System Access",
  "description": "Toggle system access for a user account and verify API response",
  "baseUrl": "https://ops-aad.ehr-test.vib",
  "tags": ["account-mgmt", "smoke"],
  "steps": [
    {
      "id": "step_0",
      "action": "navigate",
      "value": "https://ops-aad.ehr-test.vib/account-management",
      "description": "Navigate to Account Management page"
    },
    {
      "id": "step_1",
      "action": "assert_visible",
      "selector": "text=\"Account Management\"",
      "description": "Verify Account Management page loaded"
    },
    {
      "id": "step_2",
      "action": "fill",
      "selector": "placeholder=\"Search user...\"",
      "value": "testuser01",
      "description": "Search for test user"
    },
    {
      "id": "step_3",
      "action": "click",
      "selector": "role=button[name=\"Search\"]",
      "description": "Click Search button"
    },
    {
      "id": "step_4",
      "action": "wait",
      "value": "2000",
      "timeout": 2000,
      "description": "Wait for search results"
    },
    {
      "id": "step_5",
      "action": "click",
      "selector": "button[role='switch']",
      "description": "Toggle system access switch"
    },
    {
      "id": "step_6",
      "action": "assert_visible",
      "selector": "text=\"Success\"",
      "description": "Verify success notification appeared"
    }
  ],
  "createdAt": "2026-04-13T10:00:00.000Z",
  "updatedAt": "2026-04-13T10:00:00.000Z"
}
